BASE = cdm_crpix
DVI  = $(BASE).dvi
PDF  = $(BASE).pdf
PS   = $(BASE).ps
TEX  = $(BASE).tex
DIV  = ----------------------------------------------------------------------

#--------------------------------------------------------------------------

$(BASE): $(PDF) $(PS) Makefile

$(DVI): $(TEX) Makefile
	latex $(TEX)

$(PDF): $(DVI) Makefile
	dvipdf $(DVI)

$(PS) : $(DVI) Makefile
	dvips $(DVI) -o $(PS) -Ppdf -t letter

